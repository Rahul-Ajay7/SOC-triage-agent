# ============================================================
# SOC Triage Agent — environment configuration
# Copy to backend/.env and fill what you have.
# EVERYTHING optional — agent runs fully on heuristics with
# an empty file (free-first design).
# ============================================================

# ---- Application ----
APP_NAME="SOC Triage Agent"
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8001

# ---- Database (SQLite, no setup) ----
DATABASE_URL=sqlite:///./soc_triage.db

# ---- LLM fallback chain: Groq -> Gemini -> Ollama ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

LLM_BASE_URL=http://localhost:11434
LLM_CHAT_ENDPOINT=/v1/chat/completions
LLM_MODEL=llama3.1
LLM_TIMEOUT=120

# ---- Threat intel (free tier, optional) ----
# AbuseIPDB free: 1000 checks/day  https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=

# ---- Agent tuning ----
AGENT_CONFIDENCE_THRESHOLD=0.7
AGENT_MAX_ITERATIONS=2

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8001
